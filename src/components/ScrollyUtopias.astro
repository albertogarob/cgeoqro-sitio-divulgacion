---
// Scrollytelling original sobre el Programa Utopías en Iztapalapa (paper de Karol
// Yáñez Soria et al., Geopauta 2026, CC BY). Texto parafraseado; gráfico SVG propio,
// sin reproducir figuras del artículo. Ver política de derechos de autor en CLAUDE.md.

const celdas = [
  { x: 460, y: 180 }, { x: 540, y: 180 },
  { x: 380, y: 260 }, { x: 460, y: 260 }, { x: 540, y: 260 }, { x: 620, y: 260 },
  { x: 340, y: 340 }, { x: 420, y: 340 }, { x: 500, y: 340 }, { x: 580, y: 340 }, { x: 660, y: 340 },
  { x: 460, y: 420 }, { x: 540, y: 420 },
];
const nodos = [
  { x: 460, y: 180 }, { x: 540, y: 180 }, { x: 380, y: 260 }, { x: 620, y: 260 },
  { x: 340, y: 340 }, { x: 500, y: 340 }, { x: 660, y: 340 }, { x: 460, y: 420 }, { x: 540, y: 420 },
];
const enlaces = [
  ['460,180', '380,260'], ['380,260', '340,340'], ['340,340', '500,340'],
  ['500,340', '660,340'], ['660,340', '620,260'], ['620,260', '540,180'],
  ['500,340', '540,420'], ['540,420', '460,420'], ['540,180', '460,180'],
];
const exteriores = [
  { x: 120, y: 150 }, { x: 880, y: 175 }, { x: 150, y: 560 }, { x: 855, y: 545 }, { x: 500, y: 645 },
];
// Arreglo de personas (1 de cada 5): 5 columnas x 4 filas = 20; 4 resaltadas.
const personas: { x: number; y: number; on: boolean }[] = [];
for (let r = 0; r < 4; r++) {
  for (let c = 0; c < 5; c++) {
    const idx = r * 5 + c;
    personas.push({ x: 370 + c * 72, y: 225 + r * 72, on: idx % 5 === 0 });
  }
}

const pasos = [
  { n: 0, texto: 'Durante décadas, Iztapalapa fue vista como el "patio trasero" de la Ciudad de México.' },
  { n: 1, texto: 'Es la alcaldía más poblada de las dieciséis. Casi uno de cada cinco habitantes de la capital vive aquí.' },
  { n: 2, texto: 'Más de la mitad de su población habita en zonas con desarrollo social bajo o muy bajo. El trabajo de cuidar recae, sobre todo, en las mujeres.' },
  { n: 3, texto: 'Buena parte de estos barrios se construyó a mano: levantados y organizados por sus propios vecinos, con o sin apoyo del Estado.' },
  { n: 4, texto: 'Entre 2019 y 2024 surgieron centros comunitarios en los trece distritos: las Utopías.' },
  { n: 5, texto: 'No solo ofrecen servicios: tejen una red de cuidado colectivo. Unen el derecho a la ciudad con el urbanismo feminista.' },
  { n: 6, texto: 'Lo que nació en la periferia hoy se expande a toda la ciudad, con reconocimiento internacional.' },
  { n: 7, texto: '¿Hacia el derecho a las ciudades cuidadoras? Una innovación local que se vuelve política pública.' },
];
---

<section class="scrolly" data-step="0">
	<div class="scrolly-stage">
		<svg viewBox="0 0 1000 700" class="mapa" preserveAspectRatio="xMidYMid meet" aria-hidden="true">
			<defs>
				<radialGradient id="scBg" cx="50%" cy="38%" r="85%">
					<stop offset="0%" stop-color="#173352" />
					<stop offset="55%" stop-color="#0c1a2b" />
					<stop offset="100%" stop-color="#050c15" />
				</radialGradient>
				<filter id="scGlow" x="-80%" y="-80%" width="260%" height="260%">
					<feGaussianBlur stdDeviation="6" result="b" />
					<feMerge><feMergeNode in="b" /><feMergeNode in="SourceGraphic" /></feMerge>
				</filter>
			</defs>
			<rect x="0" y="0" width="1000" height="700" fill="url(#scBg)" />

			<!-- ELEMENTO PERSISTENTE: el mapa, movido por la "cámara" -->
			<g class="map">
				<g class="camera">
					<!-- Expansión a la ciudad -->
					<g class="layer" data-from="6">
						<ellipse cx="500" cy="340" rx="430" ry="330" fill="none"
							stroke="rgba(232,132,63,0.45)" stroke-width="2" stroke-dasharray="7 10" />
						{exteriores.map((e) => <circle cx={e.x} cy={e.y} r="8" fill="#e8843f" opacity="0.6" />)}
					</g>
					<!-- Celdas (13 distritos) -->
					<g class="layer" data-from="0">
						{celdas.map((c) => (
							<rect class="celda" x={c.x - 33} y={c.y - 33} width="66" height="66" rx="10"
								fill="rgba(255,255,255,0.035)" stroke="rgba(255,255,255,0.22)" stroke-width="1" />
						))}
					</g>
					<!-- Retícula "hecha a mano" (se dibuja) -->
					<g class="layer draw-grid" data-from="3" stroke="rgba(255,255,255,0.3)" stroke-width="1.2">
						{celdas.map((c) => (
							<>
								<line class="dl" x1={c.x - 33} y1={c.y} x2={c.x + 33} y2={c.y} />
								<line class="dl" x1={c.x} y1={c.y - 33} x2={c.x} y2={c.y + 33} />
							</>
						))}
					</g>
					<!-- Red de cuidados (se dibuja) -->
					<g class="layer draw-net" data-from="5" stroke="#e8843f" stroke-width="2.5" fill="none">
						{enlaces.map(([a, b]) => {
							const [x1, y1] = a.split(',');
							const [x2, y2] = b.split(',');
							return <line class="dl" x1={x1} y1={y1} x2={x2} y2={y2} />;
						})}
					</g>
					<!-- Utopías (nodos, encendido escalonado) -->
					<g class="layer nodos" data-from="4" filter="url(#scGlow)">
						{nodos.map((nd, i) => (
							<circle class="nodo" style={`--i:${i}`} cx={nd.x} cy={nd.y} r="10" fill="#e8843f" />
						))}
					</g>
				</g>
			</g>

			<!-- MOMENTO 1: 1 de cada 5 (arreglo de personas) -->
			<g class="only" data-only="1">
				{personas.map((p) => (
					<circle class:list={['persona', { hi: p.on }]} cx={p.x} cy={p.y} r="15"
						fill={p.on ? '#e8843f' : 'rgba(255,255,255,0.16)'} />
				))}
				<text class="mom-big" x="500" y="600" text-anchor="middle">1 de cada 5</text>
				<text class="mom-sub" x="500" y="635" text-anchor="middle">habitantes de la Ciudad de México</text>
			</g>

			<!-- MOMENTO 2: barra de marginación -->
			<g class="only" data-only="2">
				<rect x="270" y="300" width="460" height="46" rx="23" fill="rgba(255,255,255,0.12)" />
				<rect class="barra-fill" x="270" y="300" height="46" rx="23" fill="#c45620" />
				<text class="mom-big" x="500" y="250" text-anchor="middle">+50%</text>
				<text class="mom-sub" x="500" y="400" text-anchor="middle">vive en zonas de desarrollo social bajo o muy bajo</text>
			</g>

			<!-- MOMENTO visitas (paso 4) -->
			<g class="only" data-only="4">
				<text class="mom-big" x="500" y="590" text-anchor="middle"><tspan class="count" data-to="8">0</tspan> millones</text>
				<text class="mom-sub" x="500" y="628" text-anchor="middle">de visitas entre 2022 y 2024</text>
			</g>

			<!-- MOMENTO stats ciudad (paso 6) -->
			<g class="only" data-only="6">
				<text class="mom-big" x="300" y="120" text-anchor="middle"><tspan class="count" data-to="20">0</tspan></text>
				<text class="mom-sub" x="300" y="152" text-anchor="middle">países han venido a conocerlas</text>
				<text class="mom-big" x="710" y="120" text-anchor="middle"><tspan class="count" data-to="100">0</tspan></text>
				<text class="mom-sub" x="710" y="152" text-anchor="middle">nuevos proyectos en la ciudad</text>
			</g>

			<!-- MOMENTO final (paso 7): tres claves -->
			<g class="only" data-only="7">
				<g class="clave" style="--i:0"><rect x="120" y="600" width="230" height="60" rx="30" /><text x="235" y="637" text-anchor="middle">Liderazgo feminista</text></g>
				<g class="clave" style="--i:1"><rect x="385" y="600" width="230" height="60" rx="30" /><text x="500" y="637" text-anchor="middle">Cuidado colectivo</text></g>
				<g class="clave" style="--i:2"><rect x="650" y="600" width="230" height="60" rx="30" /><text x="765" y="637" text-anchor="middle">Política pública</text></g>
			</g>
		</svg>
	</div>

	<div class="scrolly-steps">
		{pasos.map((p) => (
			<div class="step" data-step={p.n}>
				<p class="caption">{p.texto}</p>
			</div>
		))}
	</div>
</section>

<script>
	import scrollama from 'scrollama';

	function initScrolly() {
		const container = document.querySelector<HTMLElement>('.scrolly');
		if (!container) return;
		const stage = container.querySelector<HTMLElement>('.scrolly-stage');
		const header = document.querySelector<HTMLElement>('header');
		const camera = container.querySelector<SVGGElement>('.camera');
		const map = container.querySelector<SVGGElement>('.map');
		const layers = Array.from(container.querySelectorAll<SVGGElement>('.layer'));
		const onlys = Array.from(container.querySelectorAll<SVGGElement>('.only'));

		// Encaje del escenario justo debajo del navbar (evita que lo tape).
		function setStageTop() {
			const h = header ? header.offsetHeight : 64;
			container.style.setProperty('--stage-top', h + 'px');
		}
		setStageTop();
		window.addEventListener('resize', setStageTop);

		// Cámara: encuadre por paso (paneo/zoom).
		const camaras: Record<number, string> = {
			0: 'translate(0,0) scale(1)',
			1: 'translate(0,0) scale(1)',
			2: 'translate(0,0) scale(1)',
			3: 'translate(-330,-190) scale(1.62)',
			4: 'translate(0,0) scale(1)',
			5: 'translate(0,0) scale(1)',
			6: 'translate(140,98) scale(0.72)',
			7: 'translate(110,77) scale(0.78)',
		};

		function animCount(el: Element, to: number) {
			const dur = 900;
			let start = 0;
			function frame(t: number) {
				if (!start) start = t;
				const k = Math.min(1, (t - start) / dur);
				const val = Math.round(to * (1 - Math.pow(1 - k, 3)));
				el.textContent = String(val);
				if (k < 1) requestAnimationFrame(frame);
			}
			requestAnimationFrame(frame);
		}

		function aplicar(step: number) {
			container.dataset.step = String(step);
			if (camera) camera.setAttribute('transform', camaras[step] ?? camaras[0]);
			if (map) map.classList.toggle('dim', step === 1 || step === 2);
			layers.forEach((l) => l.classList.toggle('on', step >= Number(l.dataset.from ?? '0')));
			onlys.forEach((o) => o.classList.toggle('on', step === Number(o.dataset.only)));
			// Contadores del paso activo.
			const activeOnly = onlys.find((o) => Number(o.dataset.only) === step);
			if (activeOnly) {
				activeOnly.querySelectorAll<HTMLElement>('.count').forEach((c) => {
					animCount(c, Number(c.dataset.to ?? '0'));
				});
			}
		}

		aplicar(0);

		const scroller = scrollama();
		scroller
			.setup({ step: '.scrolly .step', offset: 0.75 })
			.onStepEnter((r: { element: HTMLElement }) => {
				container.querySelectorAll('.step').forEach((el) => el.classList.remove('activo'));
				r.element.classList.add('activo');
				aplicar(Number(r.element.dataset.step ?? '0'));
			});
		window.addEventListener('resize', scroller.resize);
	}

	if (document.readyState !== 'loading') initScrolly();
	else document.addEventListener('DOMContentLoaded', initScrolly);
</script>

<style>
	.scrolly {
		--stage-top: 64px;
		position: relative;
		width: 100%;
	}
	.scrolly-stage {
		position: sticky;
		top: var(--stage-top);
		height: calc(100vh - var(--stage-top));
		width: 100%;
		background: #050c15;
		overflow: hidden;
	}
	.mapa {
		width: 100%;
		height: 100%;
		display: block;
	}
	.camera {
		transform-origin: 0 0;
		transition: transform 1000ms cubic-bezier(0.45, 0.05, 0.2, 1);
	}
	.map {
		transition: opacity 500ms ease, filter 500ms ease;
	}
	.map.dim {
		opacity: 0.28;
		filter: saturate(0.5);
	}

	/* capas acumulativas */
	.layer {
		opacity: 0;
		transition: opacity 600ms ease;
	}
	.layer.on {
		opacity: 1;
	}

	/* nodos: encendido escalonado + pulso */
	.nodos .nodo {
		opacity: 0;
		transform: scale(0.2);
		transform-origin: center;
		transform-box: fill-box;
		transition: opacity 400ms ease, transform 400ms cubic-bezier(0.34, 1.56, 0.64, 1);
		transition-delay: calc(var(--i) * 90ms);
	}
	.nodos.on .nodo {
		opacity: 1;
		transform: scale(1);
		animation: pulso 2.4s ease-in-out infinite;
		animation-delay: calc(var(--i) * 90ms + 600ms);
	}
	@keyframes pulso {
		0%, 100% { filter: none; }
		50% { r: 12; }
	}

	/* trazos que se dibujan */
	.draw-grid .dl, .draw-net .dl {
		stroke-dasharray: 80;
		stroke-dashoffset: 80;
		transition: stroke-dashoffset 700ms ease;
	}
	.draw-grid.on .dl, .draw-net.on .dl {
		stroke-dashoffset: 0;
	}
	.draw-net .dl { transition-duration: 900ms; }

	/* momentos (overlays de un solo paso) */
	.only {
		opacity: 0;
		pointer-events: none;
		transition: opacity 500ms ease;
	}
	.only.on {
		opacity: 1;
	}
	.mom-big {
		font-family: 'Archivo Expanded', sans-serif;
		font-weight: 700;
		font-size: 64px;
		fill: #ffffff;
	}
	.mom-sub {
		font-family: 'Roboto Flex', sans-serif;
		font-size: 22px;
		fill: rgba(255, 255, 255, 0.8);
	}
	.persona {
		transition: fill 300ms ease, transform 400ms cubic-bezier(0.34, 1.56, 0.64, 1);
		transform-origin: center;
		transform-box: fill-box;
	}
	.only.on .persona.hi {
		animation: saltar 500ms ease both;
	}
	@keyframes saltar {
		0% { transform: scale(0.4); }
		60% { transform: scale(1.25); }
		100% { transform: scale(1); }
	}
	.barra-fill {
		width: 0;
		transition: width 1100ms cubic-bezier(0.4, 0, 0.2, 1) 150ms;
	}
	.only.on .barra-fill {
		width: 250px;
	}
	.clave rect {
		fill: rgba(232, 132, 63, 0.16);
		stroke: #e8843f;
		stroke-width: 1.5;
		opacity: 0;
		transition: opacity 500ms ease;
		transition-delay: calc(var(--i) * 180ms);
	}
	.clave text {
		font-family: 'Roboto Flex', sans-serif;
		font-weight: 600;
		font-size: 21px;
		fill: #ffffff;
		opacity: 0;
		transition: opacity 500ms ease;
		transition-delay: calc(var(--i) * 180ms + 120ms);
	}
	.only.on .clave rect, .only.on .clave text {
		opacity: 1;
	}

	/* columna de texto flotante (subtítulos, no diapositivas) */
	.scrolly-steps {
		position: relative;
		z-index: 3;
		pointer-events: none;
		max-width: 30rem;
		margin-left: clamp(1rem, 6vw, 6rem);
	}
	.step {
		min-height: 92vh;
		display: flex;
		align-items: center;
	}
	.step:first-child { min-height: 85vh; }
	.caption {
		pointer-events: auto;
		margin: 0;
		padding: 1.1rem 1.4rem;
		font-size: clamp(1.15rem, 2.2vw, 1.6rem);
		line-height: 1.4;
		font-weight: 500;
		color: #ffffff;
		background: rgba(8, 18, 32, 0.72);
		backdrop-filter: blur(10px);
		-webkit-backdrop-filter: blur(10px);
		border-left: 3px solid #e8843f;
		border-radius: 4px;
		opacity: 0.35;
		transform: translateY(10px);
		transition: opacity 350ms ease, transform 350ms ease;
	}
	.step.activo .caption {
		opacity: 1;
		transform: translateY(0);
	}

	@media (max-width: 720px) {
		.scrolly-steps {
			max-width: none;
			margin-left: 0;
			padding: 0 1rem;
		}
		.mom-big { font-size: 52px; }
	}
</style>
