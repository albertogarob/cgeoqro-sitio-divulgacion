---
import { getEntry } from 'astro:content';
import { withBase } from '../lib/url';
import Thumb from './Thumb.astro';

const { capsula } = Astro.props;

const formatoEtiqueta: Record<string, string> = {
  video: 'Video',
  audio: 'Audio',
  infografia: 'Infografía',
  texto: 'Texto',
};
function tipoCapsula(c: any): 'scrolly' | 'video' | 'infografia' | 'audio' | 'texto' {
  if (c.data.scrolly) return 'scrolly';
  if (c.data.formatos.includes('video')) return 'video';
  if (c.data.formatos.includes('infografia')) return 'infografia';
  if (c.data.formatos.includes('audio')) return 'audio';
  return 'texto';
}

const serie = await getEntry(capsula.data.serie);
const investigadores = (await Promise.all((capsula.data.investigadores ?? []).map((ref: any) => getEntry(ref)))).filter(Boolean);
const autor = investigadores[0];
const autoresExtra = investigadores.length - 1;
const kind = tipoCapsula(capsula);
const formatoLabel = capsula.data.scrolly
  ? 'Recorrido interactivo'
  : capsula.data.formatos.map((f: string) => formatoEtiqueta[f] ?? f).join(' · ');
---

<a class="cap-card" href={withBase(`/capsulas/${capsula.id}/`)}>
	<div class="cap-card-thumb">
		<Thumb kind={kind} accent={serie?.data.colorAcento} variant={serie?.id} seed={capsula.id} />
		<span class="cap-card-formato">{formatoLabel}</span>
	</div>
	<div class="cap-card-body">
		{serie && <span class="cg-pill">{serie.data.nombre}</span>}
		<h3>{capsula.data.titulo}</h3>
		<p>{capsula.data.resumenCorto}</p>
		{autor && (
			<div class="cap-card-autor">
				{autor.data.fotoUrl ? (
					<img class="cap-card-avatar" src={withBase(autor.data.fotoUrl)} alt={autor.data.nombre} loading="lazy" />
				) : (
					<span class="cap-card-avatar cap-card-avatar-vacia" aria-hidden="true"></span>
				)}
				<span class="cap-card-autor-nombre">{autor.data.tratamiento ? `${autor.data.tratamiento} ` : ''}{autor.data.nombre}{autoresExtra > 0 ? ` +${autoresExtra}` : ''}</span>
			</div>
		)}
	</div>
</a>

<style>
	.cap-card {
		display: flex;
		flex-direction: column;
		border-radius: var(--cg-border-radius-m);
		overflow: hidden;
		background: var(--cg-color-blanco);
		border: 1px solid var(--cg-color-gris-300);
		text-decoration: none !important;
		color: var(--cg-color-gris-500) !important;
		transition: transform 150ms ease, box-shadow 150ms ease, border-color 150ms ease;
	}
	.cap-card:hover {
		transform: translateY(-4px);
		border-color: var(--cg-color-naranja-300);
		box-shadow: 0 24px 44px -30px rgba(0, 0, 0, 0.45);
	}
	.cap-card-thumb {
		position: relative;
		aspect-ratio: 16 / 10;
	}
	.cap-card-thumb :global(.cg-thumb) {
		position: absolute;
		inset: 0;
	}
	.cap-card-formato {
		position: absolute;
		left: 0.7rem;
		bottom: 0.7rem;
		z-index: 2;
		background: rgba(8, 14, 22, 0.72);
		color: #fff;
		font-size: 0.72rem;
		font-weight: 700;
		letter-spacing: 0.04em;
		text-transform: uppercase;
		padding: 0.25rem 0.6rem;
		border-radius: 999px;
		backdrop-filter: blur(4px);
	}
	.cap-card-body {
		padding: 1rem 1.15rem 1.25rem;
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
	}
	.cap-card-body h3 {
		margin: 0;
		font-size: 1.1rem;
		color: var(--cg-color-gris-700) !important;
		line-height: 1.25;
	}
	.cap-card-body p {
		margin: 0;
		font-size: 0.9rem;
		display: -webkit-box;
		-webkit-line-clamp: 3;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}
	/* Franja de autoría: promociona al investigador y da un aire más profesional. */
	.cap-card-autor {
		display: flex;
		align-items: center;
		gap: 0.6rem;
		margin-top: 0.4rem;
		padding-top: 0.85rem;
		border-top: 1px solid var(--cg-color-gris-300);
	}
	.cap-card-avatar {
		flex: 0 0 54px;
		width: 54px;
		height: 54px;
		border-radius: 50%;
		object-fit: cover;
		background: var(--cg-color-gris-300);
	}
	.cap-card-avatar-vacia {
		background: linear-gradient(140deg, #1c2531, #0e131b);
	}
	.cap-card-autor-nombre {
		font-size: 0.92rem;
		font-weight: 700;
		line-height: 1.25;
		color: var(--cg-color-gris-700) !important;
	}
</style>
