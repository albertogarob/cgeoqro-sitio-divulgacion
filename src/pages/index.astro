---
import Base from '../layouts/Base.astro';
import { getCollection, getEntry } from 'astro:content';
import { withBase } from '../lib/url';

const capsulas = (await getCollection('capsulas')).sort(
  (a, b) => b.data.fechaPublicacion.valueOf() - a.data.fechaPublicacion.valueOf()
);
const series = await getCollection('series');
const investigadores = await getCollection('investigadores');
const entrevistas = await getCollection('entrevistas');

// Conteo de cápsulas por serie para mostrar en las tarjetas de tema.
const seriesConConteo = series.map((s) => ({
  serie: s,
  total: capsulas.filter((c) => c.data.serie.id === s.id).length,
}));

// Secciones de orientación: qué puede explorar el usuario.
const explorar = [
  {
    href: '/capsulas/',
    titulo: 'Cápsulas de conocimiento',
    desc: 'Piezas breves, una por hallazgo. En video, audio, infografía o texto.',
    dato: `${capsulas.length} ${capsulas.length === 1 ? 'cápsula' : 'cápsulas'}`,
  },
  {
    href: '/series/',
    titulo: 'Series temáticas',
    desc: 'El conocimiento agrupado por tema: Agua, El espacio donde vivimos y Sociedad justa.',
    dato: `${series.length} series`,
  },
  {
    href: '/entrevistas/',
    titulo: '3 Preguntas a...',
    desc: 'Conversaciones cortas donde cada investigador explica su trabajo en primera persona.',
    dato: entrevistas.length > 0
      ? `${entrevistas.length} ${entrevistas.length === 1 ? 'entrevista' : 'entrevistas'}`
      : 'Próximamente',
  },
  {
    href: '/investigadores/',
    titulo: 'Investigadores',
    desc: 'Conoce a quienes hacen la ciencia y descubre todas sus cápsulas y publicaciones.',
    dato: `${investigadores.length} ${investigadores.length === 1 ? 'investigador' : 'investigadores'}`,
  },
];

const formatoEtiqueta = {
  video: 'Video',
  audio: 'Audio',
  infografia: 'Infografía',
  texto: 'Texto',
};

// Cápsulas reales (sin ejemplos) para el carrusel del hero, ya ordenadas por fecha.
const capsReales = capsulas.filter((c) => !c.id.startsWith('ejemplo'));
const capsCarrusel = await Promise.all(
  capsReales.map(async (c) => ({
    c,
    serie: await getEntry(c.data.serie),
    esScrolly: Boolean(c.data.scrolly),
    formatoLabel: c.data.scrolly
      ? 'Recorrido interactivo'
      : c.data.formatos.map((f) => formatoEtiqueta[f] ?? f).join(' · '),
    cta: c.data.scrolly ? 'Iniciar el recorrido' : 'Ver la cápsula',
  }))
);

// Geometría del globo terráqueo del hero (SVG original, sin usar imágenes de
// terceros, en cumplimiento de la política de derechos de autor del proyecto).
// El globo evoca lo geoespacial; los nodos y arcos, el compartir conocimiento.
const R = 200;
const cx = 250;
const cy = 250;
const persp = 0.32; // achatamiento de las líneas de latitud para dar volumen
const latitudes = [-160, -120, -80, -40, 0, 40, 80, 120, 160].map((dy) => ({
  cy: cy + dy,
  rx: Math.round(Math.sqrt(R * R - dy * dy)),
  ry: Math.round(Math.sqrt(R * R - dy * dy) * persp),
}));
const longitudes = [200, 158, 100, 30].map((rx) => ({ rx }));
// Nodos sobre la superficie y arcos que los conectan (red de divulgación).
const nodos = [
  { x: 150, y: 165 },
  { x: 330, y: 140 },
  { x: 360, y: 300 },
  { x: 175, y: 340 },
  { x: 250, y: 90 },
];
const arcos = [
  { d: 'M150,165 Q260,80 330,140' },
  { d: 'M330,140 Q400,230 360,300' },
  { d: 'M360,300 Q250,380 175,340' },
  { d: 'M250,90 Q140,120 150,165' },
];
---

<Base title="Inicio">
	<section slot="hero" class="hero" data-carrusel data-slide="0">
		<svg class="hero-globo" viewBox="0 0 500 500" aria-hidden="true" preserveAspectRatio="xMidYMid slice">
			<defs>
				<radialGradient id="globoFill" cx="38%" cy="35%" r="75%">
					<stop offset="0%" stop-color="#1b3a5c" />
					<stop offset="60%" stop-color="#0c2036" />
					<stop offset="100%" stop-color="#050d17" />
				</radialGradient>
			</defs>
			<circle cx={cx} cy={cy} r={R} fill="url(#globoFill)" stroke="rgba(255,255,255,0.18)" stroke-width="1" />
			<g fill="none" stroke="rgba(255,255,255,0.14)" stroke-width="1">
				{latitudes.map((l) => <ellipse cx={cx} cy={l.cy} rx={l.rx} ry={l.ry} />)}
				{longitudes.map((l) => <ellipse cx={cx} cy={cy} rx={l.rx} ry={R} />)}
				<line x1={cx} y1={cy - R} x2={cx} y2={cy + R} />
			</g>
			<g fill="none" stroke="#c45620" stroke-width="1.5" opacity="0.85">
				{arcos.map((a) => <path d={a.d} />)}
			</g>
			<g>
				{nodos.map((n) => (
					<circle cx={n.x} cy={n.y} r="5" fill="#e8843f" />
				))}
			</g>
		</svg>

		<div class="carrusel-viewport">
			<div class="carrusel-track">
				<!-- Slide 0: banner de bienvenida -->
				<div class="slide slide-intro">
					<div class="hero-contenido">
						<span class="hero-eyebrow">Divulgación científica · CentroGeo Querétaro</span>
						<h1>La ciencia que se produce aquí, contada para todos</h1>
						<p class="hero-sub">
							Traducimos la investigación de CentroGeo Querétaro a cápsulas breves, videos y
							entrevistas pensadas para el público general. Sin tecnicismos, sin perder rigor.
						</p>
						<div class="hero-cta">
							<a class="cg-btn cg-btn-primary" href={withBase('/capsulas/')}>Explorar las cápsulas</a>
						</div>
						<div class="hero-conoce">
							<span class="hero-conoce-label">Conócenos:</span>
							<a class="cg-btn hero-btn-fantasma" href={withBase('/acerca-de/')}>¿Qué es esto?</a>
							<a class="cg-btn hero-btn-fantasma" href={withBase('/quienes-somos/')}>¿Quiénes somos?</a>
							<a class="cg-btn hero-btn-fantasma" href={withBase('/centrogeo-queretaro/')}>¿Qué es el CentroGeo Querétaro?</a>
						</div>
					</div>
				</div>

				<!-- Slides de cápsulas -->
				{capsCarrusel.map(({ c, serie, esScrolly, formatoLabel, cta }) => (
					<div class="slide slide-capsula">
						<div class="hero-contenido">
							<span class="hero-eyebrow">
								{serie ? serie.data.nombre : 'Cápsula'} · {formatoLabel}
							</span>
							<h2>{c.data.titulo}</h2>
							<p class="hero-sub">{c.data.resumenCorto}</p>
							<div class="hero-cta">
								<a class="cg-btn cg-btn-primary" href={withBase(`/capsulas/${c.id}/`)}>{cta} &rarr;</a>
							</div>
						</div>
						<div class="slide-visual">
							{esScrolly ? (
								<svg viewBox="0 0 260 200" aria-hidden="true">
									<g stroke="#e8843f" stroke-width="2" opacity="0.85">
										<line x1="60" y1="60" x2="120" y2="50" />
										<line x1="120" y1="50" x2="180" y2="80" />
										<line x1="180" y1="80" x2="200" y2="140" />
										<line x1="200" y1="140" x2="110" y2="150" />
										<line x1="110" y1="150" x2="60" y2="60" />
										<line x1="120" y1="50" x2="110" y2="150" />
									</g>
									<g fill="#e8843f">
										<circle cx="60" cy="60" r="8" /><circle cx="120" cy="50" r="8" />
										<circle cx="180" cy="80" r="8" /><circle cx="200" cy="140" r="8" />
										<circle cx="110" cy="150" r="8" />
									</g>
								</svg>
							) : (
								<svg viewBox="0 0 200 200" aria-hidden="true">
									<circle cx="100" cy="100" r="70" fill="none" stroke="#e8843f" stroke-width="3" opacity="0.85" />
									<path d="M84,66 L142,100 L84,134 Z" fill="#e8843f" />
								</svg>
							)}
						</div>
					</div>
				))}
			</div>
		</div>

		<button class="carrusel-flecha carrusel-prev" type="button" aria-label="Anterior">&#8249;</button>
		<button class="carrusel-flecha carrusel-next" type="button" aria-label="Siguiente">&#8250;</button>
		<div class="carrusel-puntos" role="tablist" aria-label="Ir a la diapositiva"></div>
	</section>

	<section class="bloque">
		<h2>¿Qué vas a encontrar aquí?</h2>
		<div class="explorar-grid">
			{explorar.map((item) => (
				<a class="explorar-card" href={withBase(item.href)}>
					<span class="explorar-dato">{item.dato}</span>
					<h3>{item.titulo}</h3>
					<p>{item.desc}</p>
					<span class="explorar-flecha">Ver &rarr;</span>
				</a>
			))}
		</div>
	</section>

	<section class="bloque">
		<h2>Explora por tema</h2>
		<div class="series-grid">
			{seriesConConteo.map(({ serie, total }) => (
				<a
					class="serie-card"
					href={withBase(`/series/${serie.id}/`)}
					style={`--acento: ${serie.data.colorAcento ?? 'var(--cg-color-naranja-300)'}`}
				>
					<span class="serie-barra"></span>
					<h3>{serie.data.nombre}</h3>
					<p>{serie.data.descripcion}</p>
					<span class="serie-conteo">
						{total > 0 ? `${total} ${total === 1 ? 'cápsula' : 'cápsulas'}` : 'Próximamente'}
					</span>
				</a>
			))}
		</div>
	</section>

	<style>
		/* ── HERO de ancho completo (banda oscura estilo espacial) ── */
		.hero {
			position: relative;
			overflow: hidden;
			background:
				radial-gradient(120% 140% at 82% 20%, rgba(196, 86, 32, 0.35) 0%, rgba(196, 86, 32, 0) 55%),
				linear-gradient(135deg, #0a1c30 0%, #0c141d 55%, #140b06 100%);
			color: #ffffff;
		}
		.hero-globo {
			position: absolute;
			top: 50%;
			right: -4%;
			transform: translateY(-50%);
			height: 150%;
			width: auto;
			aspect-ratio: 1 / 1;
			opacity: 0.9;
			pointer-events: none;
		}
		.hero-contenido {
			position: relative;
			z-index: 1;
		}
		/* ── Carrusel ── */
		.carrusel-viewport {
			position: relative;
			z-index: 1;
			overflow: hidden;
		}
		.carrusel-track {
			display: flex;
			transition: transform 500ms cubic-bezier(0.4, 0, 0.2, 1);
		}
		.slide {
			flex: 0 0 auto;
			min-height: clamp(30rem, 66vh, 40rem);
			display: flex;
			align-items: center;
			box-sizing: border-box;
		}
		.slide-intro .hero-contenido {
			max-width: 64rem;
			margin: 0 auto;
			padding: clamp(2.5rem, 6vw, 4.5rem) 1.5rem;
			width: 100%;
		}
		.slide-capsula {
			max-width: 64rem;
			width: 100%;
			margin: 0 auto;
			padding: clamp(2.5rem, 6vw, 4.5rem) 1.5rem;
			display: grid;
			grid-template-columns: 1.5fr 1fr;
			gap: 2.5rem;
			align-items: center;
		}
		.slide-visual {
			display: flex;
			justify-content: center;
		}
		.slide-visual svg {
			width: 100%;
			max-width: 220px;
			height: auto;
		}
		.carrusel-flecha {
			position: absolute;
			top: 50%;
			transform: translateY(-50%);
			z-index: 3;
			width: 44px;
			height: 44px;
			border-radius: 50%;
			border: 1px solid rgba(255, 255, 255, 0.4);
			background: rgba(255, 255, 255, 0.1);
			color: #ffffff;
			font-size: 1.6rem;
			line-height: 1;
			cursor: pointer;
			transition: background-color 150ms ease, border-color 150ms ease;
		}
		.carrusel-flecha:hover {
			background: rgba(255, 255, 255, 0.22);
			border-color: #ffffff;
		}
		.carrusel-prev { left: 1rem; }
		.carrusel-next { right: 1rem; }
		.carrusel-puntos {
			position: absolute;
			bottom: 1rem;
			left: 0;
			right: 0;
			display: flex;
			justify-content: center;
			gap: 0.5rem;
			z-index: 3;
		}
		.carrusel-puntos :global(.punto) {
			width: 9px;
			height: 9px;
			padding: 0;
			border-radius: 50%;
			border: none;
			background: rgba(255, 255, 255, 0.35);
			cursor: pointer;
			transition: background-color 150ms ease, transform 150ms ease;
		}
		.carrusel-puntos :global(.punto.activo) {
			background: #e8843f;
			transform: scale(1.25);
		}
		.hero-eyebrow {
			display: block;
			font-size: 0.8rem;
			font-weight: 700;
			color: #e8843f;
			text-transform: uppercase;
			letter-spacing: 0.12em;
			margin-bottom: 0.75rem;
		}
		.hero h1,
		.hero h2 {
			color: #ffffff;
			font-size: clamp(1.8rem, 4.4vw, 3rem);
			line-height: 1.1;
			margin: 0 0 1.1rem 0;
			max-width: 20ch;
		}
		.hero-sub {
			font-size: clamp(1rem, 2vw, 1.2rem);
			color: rgba(255, 255, 255, 0.82);
			max-width: 40rem;
			margin: 0 0 2rem 0;
			line-height: 1.5;
		}
		.hero-cta {
			display: flex;
			flex-wrap: wrap;
			gap: 0.75rem;
			margin-bottom: 1.5rem;
		}
		.hero-conoce {
			display: flex;
			flex-wrap: wrap;
			align-items: center;
			gap: 0.6rem;
		}
		.hero-conoce-label {
			font-size: 0.82rem;
			font-weight: 600;
			text-transform: uppercase;
			letter-spacing: 0.08em;
			color: rgba(255, 255, 255, 0.6);
			margin-right: 0.25rem;
		}
		.hero-conoce .hero-btn-fantasma {
			padding: 0.5rem 1rem;
			font-size: 0.88rem;
		}
		.hero-btn-fantasma {
			background: rgba(255, 255, 255, 0.08);
			color: #ffffff !important;
			border: 1px solid rgba(255, 255, 255, 0.4);
		}
		.hero-btn-fantasma:hover {
			background: rgba(255, 255, 255, 0.18);
			border-color: #ffffff;
		}
		@media (max-width: 720px) {
			.hero-globo {
				right: -30%;
				opacity: 0.35;
			}
			.slide-capsula {
				grid-template-columns: 1fr;
				gap: 1rem;
			}
			.slide-visual {
				display: none;
			}
			.carrusel-prev { left: 0.25rem; }
			.carrusel-next { right: 0.25rem; }
		}

		.bloque {
			margin-bottom: 3rem;
		}
		.bloque:first-of-type {
			margin-top: 0;
		}
		.bloque > h2 {
			margin-top: 0;
		}

		.explorar-grid {
			display: grid;
			grid-template-columns: repeat(auto-fit, minmax(15rem, 1fr));
			gap: 1rem;
		}
		.explorar-card {
			display: flex;
			flex-direction: column;
			padding: 1.5rem;
			border-radius: var(--cg-border-radius-m);
			background: var(--cg-color-gris-100);
			border: 1px solid transparent;
			text-decoration: none !important;
			color: var(--cg-color-gris-500) !important;
			transition: border-color 150ms ease, transform 150ms ease, background-color 150ms ease;
		}
		.explorar-card:hover {
			background: var(--cg-color-blanco);
			border-color: var(--cg-color-naranja-300);
			transform: translateY(-3px);
		}
		.explorar-dato {
			font-size: 0.8rem;
			font-weight: 700;
			color: var(--cg-color-naranja-300);
			text-transform: uppercase;
			letter-spacing: 0.05em;
		}
		.explorar-card h3 {
			margin: 0.4rem 0;
			color: var(--cg-color-gris-700) !important;
			font-size: 1.15rem;
		}
		.explorar-card p {
			margin: 0 0 1rem 0;
			font-size: 0.92rem;
			flex-grow: 1;
		}
		.explorar-flecha {
			font-weight: 600;
			color: var(--cg-color-naranja-300);
			font-size: 0.9rem;
		}

		.series-grid {
			display: grid;
			grid-template-columns: repeat(auto-fit, minmax(15rem, 1fr));
			gap: 1rem;
		}
		.serie-card {
			position: relative;
			display: flex;
			flex-direction: column;
			padding: 1.5rem;
			padding-top: 1.75rem;
			border-radius: var(--cg-border-radius-m);
			background: var(--cg-color-blanco);
			border: 1px solid var(--cg-color-gris-300);
			text-decoration: none !important;
			color: var(--cg-color-gris-500) !important;
			overflow: hidden;
			transition: transform 150ms ease, box-shadow 150ms ease;
		}
		.serie-card:hover {
			transform: translateY(-3px);
			box-shadow: 0 20px 40px -30px rgba(0, 0, 0, 0.4);
		}
		.serie-barra {
			position: absolute;
			top: 0;
			left: 0;
			right: 0;
			height: 5px;
			background: var(--acento);
		}
		.serie-card h3 {
			margin: 0 0 0.5rem 0;
			color: var(--cg-color-gris-700) !important;
		}
		.serie-card p {
			margin: 0 0 1rem 0;
			font-size: 0.92rem;
			flex-grow: 1;
		}
		.serie-conteo {
			font-size: 0.82rem;
			font-weight: 600;
			color: var(--acento);
		}

	</style>

	<script>
		function initCarrusel() {
			const root = document.querySelector<HTMLElement>('.hero[data-carrusel]');
			if (!root) return;
			const track = root.querySelector<HTMLElement>('.carrusel-track');
			const slides = Array.from(root.querySelectorAll<HTMLElement>('.slide'));
			const dotsWrap = root.querySelector<HTMLElement>('.carrusel-puntos');
			if (!track || !dotsWrap || slides.length === 0) return;

			const n = slides.length;
			let idx = 0;
			let timer: ReturnType<typeof setInterval> | null = null;
			const DELAY = 5000;
			const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

			// Anchos explícitos: track = n pantallas, cada slide = 1/n del track.
			track.style.width = `${n * 100}%`;
			slides.forEach((s) => { s.style.width = `${100 / n}%`; });
			// Con "reducir movimiento" el avance es instantáneo (sin deslizamiento),
			// pero el carrusel sigue pasando solo, como se pidió explícitamente.
			if (reduce) track.style.transition = 'none';

			slides.forEach((_, i) => {
				const b = document.createElement('button');
				b.className = 'punto';
				b.setAttribute('role', 'tab');
				b.setAttribute('aria-label', `Diapositiva ${i + 1}`);
				b.addEventListener('click', () => { go(i); reset(); });
				dotsWrap.appendChild(b);
			});
			const dots = Array.from(dotsWrap.querySelectorAll<HTMLElement>('.punto'));

			function go(i: number) {
				idx = (i + n) % n;
				track!.style.transform = `translateX(-${idx * (100 / n)}%)`;
				root!.dataset.slide = String(idx);
				dots.forEach((d, j) => d.classList.toggle('activo', j === idx));
			}
			function play() { stop(); timer = setInterval(() => go(idx + 1), DELAY); }
			function stop() { if (timer) clearInterval(timer); timer = null; }
			function reset() { stop(); play(); }

			root.querySelector('.carrusel-prev')?.addEventListener('click', () => { go(idx - 1); reset(); });
			root.querySelector('.carrusel-next')?.addEventListener('click', () => { go(idx + 1); reset(); });
			root.addEventListener('mouseenter', stop);
			root.addEventListener('mouseleave', play);
			root.addEventListener('focusin', stop);
			root.addEventListener('focusout', play);

			// Swipe en móvil.
			let sx = 0;
			track.addEventListener('touchstart', (e) => { sx = e.touches[0].clientX; stop(); }, { passive: true });
			track.addEventListener('touchend', (e) => {
				const dx = e.changedTouches[0].clientX - sx;
				if (Math.abs(dx) > 40) go(idx + (dx < 0 ? 1 : -1));
				play();
			}, { passive: true });

			go(0);
			play();
		}

		if (document.readyState !== 'loading') initCarrusel();
		else document.addEventListener('DOMContentLoaded', initCarrusel);
	</script>
</Base>
