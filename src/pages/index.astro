---
import Base from '../layouts/Base.astro';
import { getCollection, getEntry } from 'astro:content';
import { withBase } from '../lib/url';

const capsulas = (await getCollection('capsulas')).sort(
  (a, b) => b.data.fechaPublicacion.valueOf() - a.data.fechaPublicacion.valueOf()
);
const series = await getCollection('series');

const capsulasConSerie = await Promise.all(
  capsulas.map(async (c) => ({ capsula: c, serie: await getEntry(c.data.serie) }))
);
---

<Base title="Inicio">
	<span class="cg-eyebrow">CentroGeo Querétaro</span>
	<h1>Ciencia explicada para todos</h1>
	<p class="cg-intro">
		Cápsulas cortas, videos y entrevistas que traducen la investigación de CentroGeo QRO
		a un lenguaje accesible, sin perder rigor.
	</p>

	<section>
		<h2>Series temáticas</h2>
		<ul class="series-lista">
			{series.map((s) => (
				<li>
					<a class="cg-list-card" href={withBase(`/series/${s.id}/`)}>
						<h3>{s.data.nombre}</h3>
						<p>{s.data.descripcion}</p>
					</a>
				</li>
			))}
		</ul>
	</section>

	<section>
		<h2>Últimas cápsulas de conocimiento</h2>
		<ul class="capsulas-lista">
			{capsulasConSerie.map(({ capsula, serie }) => (
				<li>
					<a class="cg-list-card" href={withBase(`/capsulas/${capsula.id}/`)}>
						<h3>{capsula.data.titulo}</h3>
						{serie && <span class="cg-pill">{serie.data.nombre}</span>}
						<p>{capsula.data.resumenCorto}</p>
					</a>
				</li>
			))}
		</ul>
	</section>

	<style>
		.cg-intro {
			font-size: 1.1rem;
			max-width: 42rem;
		}
		section {
			margin-top: 2.5rem;
		}
		.series-lista,
		.capsulas-lista {
			list-style: none;
			padding: 0;
			margin: 0;
		}
		.series-lista h3,
		.capsulas-lista h3 {
			color: var(--cg-color-gris-700);
		}
	</style>
</Base>
