---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';
import { withBase } from '../../lib/url';
import Thumb from '../../components/Thumb.astro';

const investigadores = await getCollection('investigadores');
---

<Base title="Investigadores">
	<span class="cg-eyebrow">Divulgación</span>
	<h1>Investigadores de CentroGeo Querétaro</h1>
	<ul class="lista">
		{investigadores.map((inv) => (
			<li>
				<a class="cg-list-card" href={withBase(`/investigadores/${inv.id}/`)}>
					<Thumb kind="investigador" foto={inv.data.fotoUrl} label={inv.data.nombre} seed={inv.id} />
					<div class="cg-list-body">
						<h3>{inv.data.nombre}</h3>
						<p>{inv.data.bioBreve}</p>
					</div>
				</a>
			</li>
		))}
	</ul>
	<style>
		.lista {
			list-style: none;
			padding: 0;
			margin: 0;
		}
	</style>
</Base>
