---
import Base from '../../layouts/Base.astro';
import { getCollection, getEntry } from 'astro:content';
import { withBase } from '../../lib/url';

export async function getStaticPaths() {
  const entrevistas = await getCollection('entrevistas');
  return entrevistas.map((entrevista) => ({ params: { id: entrevista.id }, props: { entrevista } }));
}

const { entrevista } = Astro.props;
const investigador = await getEntry(entrevista.data.investigador);
const paper = entrevista.data.paperRelacionado ? await getEntry(entrevista.data.paperRelacionado) : null;
const tieneVideo = Boolean(entrevista.data.videoUrl);
---

<Base title={investigador ? `3 preguntas a ${investigador.data.nombre}` : 'Entrevista'} bleed={tieneVideo}>
	{tieneVideo ? (
		<>
			<div class="ent-wrap ent-intro">
				<p><a href={withBase('/entrevistas/')}>← Todas las entrevistas</a></p>
				<h1>3 preguntas a {investigador?.data.nombre}</h1>
				{investigador && (
					<p class="meta"><a href={withBase(`/investigadores/${investigador.id}/`)}>Ver perfil de {investigador.data.nombre}</a></p>
				)}
			</div>

			<div class="cine">
				<div class="cine-inner">
					<div class="cine-video">
						<iframe
							src={entrevista.data.videoUrl}
							allow="autoplay; fullscreen; picture-in-picture"
							allowfullscreen
							loading="lazy"
							title={`Entrevista en video: ${investigador?.data.nombre ?? ''}`}
						></iframe>
					</div>
					{entrevista.data.videoNota && <p class="cine-nota">{entrevista.data.videoNota}</p>}
				</div>
			</div>

			<div class="ent-wrap ent-outro">
				<ol class="preguntas">
					{entrevista.data.preguntas.map((qa) => (
						<li>
							<p class="pregunta">{qa.pregunta}</p>
							<p class="respuesta">{qa.respuesta}</p>
						</li>
					))}
				</ol>
				{paper && (
					<p class="meta">
						A propósito de: {paper.data.titulo}. {paper.data.editorial} ({paper.data.anioPublicacion})
					</p>
				)}
			</div>
		</>
	) : (
		<>
			<p><a href={withBase('/entrevistas/')}>← Todas las entrevistas</a></p>
			<h1>3 preguntas a {investigador?.data.nombre}</h1>
			{investigador && (
				<p class="meta"><a href={withBase(`/investigadores/${investigador.id}/`)}>Ver perfil de {investigador.data.nombre}</a></p>
			)}

			<ol class="preguntas">
				{entrevista.data.preguntas.map((qa) => (
					<li>
						<p class="pregunta">{qa.pregunta}</p>
						<p class="respuesta">{qa.respuesta}</p>
					</li>
				))}
			</ol>

			{paper && (
				<p class="meta">
					A propósito de: {paper.data.titulo}. {paper.data.editorial} ({paper.data.anioPublicacion})
				</p>
			)}
		</>
	)}

	<style>
		.ent-wrap {
			max-width: 46rem;
			margin: 0 auto;
			padding: 0 1.5rem;
		}
		.ent-intro {
			padding-top: 2.5rem;
			padding-bottom: 2rem;
		}
		.ent-outro {
			padding-top: 2.5rem;
			padding-bottom: 3rem;
		}
		.preguntas {
			list-style: none;
			padding: 0;
		}
		.preguntas li {
			margin-bottom: 1.5rem;
		}
		.pregunta {
			font-weight: 700;
		}
		.meta {
			color: #666;
			font-size: 0.9rem;
		}

		/* ── Modo cine para la entrevista en video (full-bleed) ── */
		.cine {
			background: radial-gradient(120% 100% at 50% 0%, #16181c 0%, #0a0a0b 70%);
			padding: clamp(1.5rem, 4vw, 3.5rem) 1rem;
		}
		.cine-inner {
			max-width: min(94vw, 1280px);
			margin: 0 auto;
		}
		.cine-video {
			position: relative;
			width: 100%;
			aspect-ratio: 16 / 9;
			border-radius: 12px;
			overflow: hidden;
			background: #000;
			box-shadow: 0 40px 90px -45px rgba(0, 0, 0, 0.9);
		}
		.cine-video iframe {
			position: absolute;
			inset: 0;
			width: 100%;
			height: 100%;
			border: 0;
		}
		.cine-nota {
			text-align: center;
			color: rgba(255, 255, 255, 0.55);
			font-size: 0.85rem;
			margin: 1rem 0 0 0;
		}
	</style>
</Base>
