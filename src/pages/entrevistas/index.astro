---
import Base from '../../layouts/Base.astro';
import { getCollection, getEntry } from 'astro:content';
import { withBase } from '../../lib/url';

const entrevistas = (await getCollection('entrevistas')).sort(
  (a, b) => b.data.fechaPublicacion.valueOf() - a.data.fechaPublicacion.valueOf()
);
const conInvestigador = await Promise.all(
  entrevistas.map(async (e) => ({ entrevista: e, investigador: await getEntry(e.data.investigador) }))
);
---

<Base title="3 Preguntas a...">
	<span class="cg-eyebrow">Divulgación</span>
	<h1>3 Preguntas a...</h1>
	<p>Entrevistas breves con investigadores de CentroGeo Querétaro sobre su trabajo.</p>
	{conInvestigador.length === 0 ? (
		<p class="vacio">Próximamente publicaremos las primeras entrevistas.</p>
	) : (
		<ul class="lista">
			{conInvestigador.map(({ entrevista, investigador }) => (
				<li>
					<a class="cg-list-card" href={withBase(`/entrevistas/${entrevista.id}/`)}>
						<h3>{investigador ? investigador.data.nombre : entrevista.id}</h3>
						<p>{entrevista.data.preguntas[0].pregunta}</p>
					</a>
				</li>
			))}
		</ul>
	)}
	<style>
		.lista {
			list-style: none;
			padding: 0;
			margin: 0;
		}
		.vacio {
			color: #666;
			font-style: italic;
		}
	</style>
</Base>
