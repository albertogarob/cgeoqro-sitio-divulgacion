---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';
import { withBase } from '../../lib/url';
import Thumb from '../../components/Thumb.astro';

const series = await getCollection('series');
---

<Base title="Series">
	<span class="cg-eyebrow">Divulgación</span>
	<h1>Series temáticas</h1>
	<p>Los ejes de investigación de CentroGeo Querétaro agrupados por tema.</p>
	<ul class="lista">
		{series.map((s) => (
			<li>
				<a class="cg-list-card" href={withBase(`/series/${s.id}/`)}>
					<Thumb kind="serie" accent={s.data.colorAcento} variant={s.id} label={s.data.nombre} seed={s.id} />
					<div class="cg-list-body">
						<h3>{s.data.nombre}</h3>
						<p>{s.data.descripcion}</p>
					</div>
				</a>
			</li>
		))}
	</ul>
	<style>
		.lista {
			list-style: none;
			padding: 0;
			margin: 0;
		}
	</style>
</Base>
