---
import Base from '../../layouts/Base.astro';
import { getCollection, getEntry } from 'astro:content';
import { withBase } from '../../lib/url';

const capsulas = (await getCollection('capsulas')).sort(
  (a, b) => b.data.fechaPublicacion.valueOf() - a.data.fechaPublicacion.valueOf()
);

const capsulasConSerie = await Promise.all(
  capsulas.map(async (c) => ({ capsula: c, serie: await getEntry(c.data.serie) }))
);
---

<Base title="Cápsulas de conocimiento">
	<span class="cg-eyebrow">Divulgación</span>
	<h1>Cápsulas de conocimiento</h1>
	<p>Unidades breves de divulgación, una por hallazgo o tema, disponibles en varios formatos.</p>

	<ul class="capsulas-lista">
		{capsulasConSerie.map(({ capsula, serie }) => (
			<li>
				<a class="cg-list-card" href={withBase(`/capsulas/${capsula.id}/`)}>
					<h3>{capsula.data.titulo}</h3>
					<p class="meta">
						{serie && <span class="cg-pill">{serie.data.nombre}</span>}
						{' '}
						<span class="cg-pill cg-pill-outline">{capsula.data.formatos.join(', ')}</span>
					</p>
					<p>{capsula.data.resumenCorto}</p>
				</a>
			</li>
		))}
	</ul>

	<style>
		.capsulas-lista {
			list-style: none;
			padding: 0;
			margin: 0;
		}
		.meta {
			display: flex;
			gap: 0.5rem;
			margin: 0.5rem 0;
		}
		.cg-pill-outline {
			background: var(--cg-color-gris-100);
			color: var(--cg-color-gris-500);
		}
	</style>
</Base>
