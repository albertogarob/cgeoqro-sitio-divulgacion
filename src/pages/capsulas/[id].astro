---
import Base from '../../layouts/Base.astro';
import { getCollection, getEntry, render } from 'astro:content';
import { withBase } from '../../lib/url';
import ScrollyUtopias from '../../components/ScrollyUtopias.astro';
import ScrollySequias from '../../components/ScrollySequias.astro';

export async function getStaticPaths() {
  const capsulas = await getCollection('capsulas');
  return capsulas.map((capsula) => ({ params: { id: capsula.id }, props: { capsula } }));
}

// Componentes de scrollytelling disponibles, indexados por la clave `scrolly`.
const scrollyComponents: Record<string, any> = { utopias: ScrollyUtopias, sequias: ScrollySequias };

const { capsula } = Astro.props;
const { Content } = await render(capsula);
const ScrollyComp = capsula.data.scrolly ? scrollyComponents[capsula.data.scrolly] : null;
const esVideo = Boolean(capsula.data.videoUrl) && !ScrollyComp;

const serie = await getEntry(capsula.data.serie);
const paper = await getEntry(capsula.data.paperFuente);
const investigadores = await Promise.all(capsula.data.investigadores.map((ref) => getEntry(ref)));

// Los créditos se repiten en varios layouts.
const creditos = { investigadores, paper, revisadoPor: capsula.data.revisadoPor };
---

<Base title={capsula.data.titulo} bleed={Boolean(ScrollyComp) || esVideo}>
	{ScrollyComp ? (
		<>
			<div class="cap-wrap cap-intro">
				<p><a href={withBase('/capsulas/')}>← Todas las cápsulas</a></p>
				<h1>{capsula.data.titulo}</h1>
				<p class="meta">
					{serie && <a href={withBase(`/series/${serie.id}/`)}>{serie.data.nombre}</a>}
					{' · Recorrido interactivo'}
				</p>
				<p class="resumen"><strong>{capsula.data.resumenCorto}</strong></p>
				<p class="scroll-hint">Desplázate para recorrer la historia ↓</p>
			</div>

			<ScrollyComp />

			<div class="cap-wrap cap-outro">
				<article><Content /></article>
				<section class="atribucion">
					<h2>Fuente y créditos</h2>
					<ul>
						<li>
							Investigadores: {creditos.investigadores.map((inv, i) => (
								<>
									{i > 0 && ', '}
									{inv && <a href={withBase(`/investigadores/${inv.id}/`)}>{inv.data.nombre}</a>}
								</>
							))}
						</li>
						{creditos.paper && (
							<li>
								Basado en (referencia, sin reproducir el texto original): {creditos.paper.data.titulo}
								{'. '}{creditos.paper.data.editorial} ({creditos.paper.data.anioPublicacion})
							</li>
						)}
						<li>Revisado por: {creditos.revisadoPor}</li>
					</ul>
				</section>
			</div>
		</>
	) : esVideo ? (
		<>
			<div class="cap-wrap cap-intro">
				<p><a href={withBase('/capsulas/')}>← Todas las cápsulas</a></p>
				<h1>{capsula.data.titulo}</h1>
				<p class="meta">
					{serie && <a href={withBase(`/series/${serie.id}/`)}>{serie.data.nombre}</a>}
					{' · Video'}
				</p>
				<p class="resumen"><strong>{capsula.data.resumenCorto}</strong></p>
			</div>

			<div class="cine">
				<div class="cine-inner">
					<div class="cine-video">
						<iframe
							src={capsula.data.videoUrl}
							allow="autoplay; fullscreen"
							allowfullscreen
							loading="lazy"
							title={`Video: ${capsula.data.titulo}`}
						></iframe>
					</div>
					<p class="cine-fallback">
						¿No carga el video? Puede deberse a permisos de Google Drive. {capsula.data.fuenteExternaUrl ? (
							<a href={capsula.data.fuenteExternaUrl} target="_blank" rel="noopener">Míralo en la fuente original</a>
						) : (
							<a href={capsula.data.videoUrl} target="_blank" rel="noopener">Ábrelo en una pestaña nueva</a>
						)}.
					</p>
				</div>
			</div>

			<div class="cap-wrap cap-outro">
				<article><Content /></article>
				<section class="atribucion">
					<h2>Fuente y créditos</h2>
					<ul>
						<li>
							Investigadores: {creditos.investigadores.map((inv, i) => (
								<>
									{i > 0 && ', '}
									{inv && <a href={withBase(`/investigadores/${inv.id}/`)}>{inv.data.nombre}</a>}
								</>
							))}
						</li>
						{creditos.paper && (
							<li>
								Basado en (referencia, sin reproducir el texto original): {creditos.paper.data.titulo}
								{'. '}{creditos.paper.data.editorial} ({creditos.paper.data.anioPublicacion})
							</li>
						)}
						<li>Revisado por: {creditos.revisadoPor}</li>
					</ul>
				</section>
			</div>
		</>
	) : (
		<>
			<p><a href={withBase('/capsulas/')}>← Todas las cápsulas</a></p>
			<h1>{capsula.data.titulo}</h1>
			<p class="meta">
				{serie && <a href={withBase(`/series/${serie.id}/`)}>{serie.data.nombre}</a>}
				{' · '}
				{capsula.data.formatos.join(', ')}
			</p>

			<p class="resumen"><strong>{capsula.data.resumenCorto}</strong></p>

			{capsula.data.audioUrl && (
				<p><a href={capsula.data.audioUrl} target="_blank" rel="noopener">Escuchar audio</a></p>
			)}

			<article>
				<Content />
			</article>

			<section class="atribucion">
				<h2>Fuente y créditos</h2>
				<ul>
					<li>
						Investigadores: {creditos.investigadores.map((inv, i) => (
							<>
								{i > 0 && ', '}
								{inv && <a href={withBase(`/investigadores/${inv.id}/`)}>{inv.data.nombre}</a>}
							</>
						))}
					</li>
					{creditos.paper && (
						<li>
							Basado en (referencia, sin reproducir el texto original): {creditos.paper.data.titulo}
							{'. '}{creditos.paper.data.editorial} ({creditos.paper.data.anioPublicacion})
						</li>
					)}
					<li>Revisado por: {creditos.revisadoPor}</li>
				</ul>
			</section>
		</>
	)}

	<style>
		.cap-wrap {
			max-width: 46rem;
			margin: 0 auto;
			padding: 0 1.5rem;
		}
		.cap-intro {
			padding-top: 2.5rem;
			padding-bottom: 2rem;
		}
		.cap-outro {
			padding-top: 2.5rem;
			padding-bottom: 3rem;
		}
		.scroll-hint {
			color: var(--cg-color-naranja-300);
			font-weight: 600;
			font-size: 0.95rem;
			margin-top: 1.5rem;
		}
		.meta {
			color: #666;
			font-size: 0.9rem;
		}
		.resumen {
			font-size: 1.1rem;
		}
		.atribucion {
			margin-top: 2.5rem;
			padding-top: 1.5rem;
			border-top: 1px solid #eee;
			font-size: 0.9rem;
			color: #444;
		}

		/* ── Modo cine para cápsulas de video (full-bleed) ── */
		.cine {
			background: radial-gradient(120% 100% at 50% 0%, #16181c 0%, #0a0a0b 70%);
			padding: clamp(1.5rem, 4vw, 3.5rem) 1rem;
		}
		.cine-inner {
			max-width: min(94vw, 1280px);
			margin: 0 auto;
		}
		.cine-video {
			position: relative;
			width: 100%;
			aspect-ratio: 16 / 9;
			border-radius: 12px;
			overflow: hidden;
			background: #000;
			box-shadow: 0 40px 90px -45px rgba(0, 0, 0, 0.9);
		}
		.cine-video iframe {
			position: absolute;
			inset: 0;
			width: 100%;
			height: 100%;
			border: 0;
		}
		.cine-fallback {
			text-align: center;
			color: rgba(255, 255, 255, 0.55);
			font-size: 0.85rem;
			margin: 1rem 0 0 0;
		}
		.cine-fallback a {
			color: var(--cg-color-naranja-300);
		}
	</style>
</Base>
