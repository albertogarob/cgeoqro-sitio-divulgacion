---
import Base from '../../layouts/Base.astro';
import { getCollection, getEntry, render } from 'astro:content';
import { withBase } from '../../lib/url';
import ScrollyUtopias from '../../components/ScrollyUtopias.astro';

export async function getStaticPaths() {
  const capsulas = await getCollection('capsulas');
  return capsulas.map((capsula) => ({ params: { id: capsula.id }, props: { capsula } }));
}

// Componentes de scrollytelling disponibles, indexados por la clave `scrolly`.
const scrollyComponents: Record<string, any> = { utopias: ScrollyUtopias };

const { capsula } = Astro.props;
const { Content } = await render(capsula);
const ScrollyComp = capsula.data.scrolly ? scrollyComponents[capsula.data.scrolly] : null;

const serie = await getEntry(capsula.data.serie);
const paper = await getEntry(capsula.data.paperFuente);
const investigadores = await Promise.all(capsula.data.investigadores.map((ref) => getEntry(ref)));
---

<Base title={capsula.data.titulo} bleed={Boolean(ScrollyComp)}>
	{ScrollyComp ? (
		<>
			<div class="cap-wrap cap-intro">
				<p><a href={withBase('/capsulas/')}>← Todas las cápsulas</a></p>
				<h1>{capsula.data.titulo}</h1>
				<p class="meta">
					{serie && <a href={withBase(`/series/${serie.id}/`)}>{serie.data.nombre}</a>}
					{' · Recorrido interactivo'}
				</p>
				<p class="resumen"><strong>{capsula.data.resumenCorto}</strong></p>
				<p class="scroll-hint">Desplázate para recorrer la historia ↓</p>
			</div>

			<ScrollyComp />

			<div class="cap-wrap cap-outro">
				<article><Content /></article>
				<section class="atribucion">
					<h2>Fuente y créditos</h2>
					<ul>
						<li>
							Investigadores: {investigadores.map((inv, i) => (
								<>
									{i > 0 && ', '}
									{inv && <a href={withBase(`/investigadores/${inv.id}/`)}>{inv.data.nombre}</a>}
								</>
							))}
						</li>
						{paper && (
							<li>
								Basado en (referencia, sin reproducir el texto original): {paper.data.titulo}
								{'. '}{paper.data.editorial} ({paper.data.anioPublicacion})
							</li>
						)}
						<li>Revisado por: {capsula.data.revisadoPor}</li>
					</ul>
				</section>
			</div>
		</>
	) : (
		<>
			<p><a href={withBase('/capsulas/')}>← Todas las cápsulas</a></p>
			<h1>{capsula.data.titulo}</h1>
			<p class="meta">
				{serie && <a href={withBase(`/series/${serie.id}/`)}>{serie.data.nombre}</a>}
				{' · '}
				{capsula.data.formatos.join(', ')}
			</p>

			<p class="resumen"><strong>{capsula.data.resumenCorto}</strong></p>

			{capsula.data.videoUrl && (
				<>
					<div class="video-wrapper">
						<iframe
							src={capsula.data.videoUrl}
							allow="autoplay"
							allowfullscreen
							loading="lazy"
							title={`Video: ${capsula.data.titulo}`}
						></iframe>
					</div>
					<p class="video-fallback">
						Este video puede no cargar en algunos navegadores por permisos de Google
						Drive. {capsula.data.fuenteExternaUrl ? (
							<a href={capsula.data.fuenteExternaUrl} target="_blank" rel="noopener">Míralo directamente en la fuente original</a>
						) : (
							<a href={capsula.data.videoUrl} target="_blank" rel="noopener">Ábrelo en una pestaña nueva</a>
						)}.
					</p>
				</>
			)}
			{capsula.data.audioUrl && (
				<p><a href={capsula.data.audioUrl} target="_blank" rel="noopener">Escuchar audio</a></p>
			)}

			<article>
				<Content />
			</article>

			<section class="atribucion">
				<h2>Fuente y créditos</h2>
				<ul>
					<li>
						Investigadores: {investigadores.map((inv, i) => (
							<>
								{i > 0 && ', '}
								{inv && <a href={withBase(`/investigadores/${inv.id}/`)}>{inv.data.nombre}</a>}
							</>
						))}
					</li>
					{paper && (
						<li>
							Basado en (referencia, sin reproducir el texto original): {paper.data.titulo}
							{'. '}{paper.data.editorial} ({paper.data.anioPublicacion})
						</li>
					)}
					<li>Revisado por: {capsula.data.revisadoPor}</li>
				</ul>
			</section>
		</>
	)}

	<style>
		.cap-wrap {
			max-width: 46rem;
			margin: 0 auto;
			padding: 0 1.5rem;
		}
		.cap-intro {
			padding-top: 2.5rem;
			padding-bottom: 2rem;
		}
		.cap-outro {
			padding-top: 2.5rem;
			padding-bottom: 3rem;
		}
		.scroll-hint {
			color: var(--cg-color-naranja-300);
			font-weight: 600;
			font-size: 0.95rem;
			margin-top: 1.5rem;
		}
		.video-wrapper {
			position: relative;
			width: 100%;
			padding-top: 56.25%;
			margin: 1.5rem 0;
			border-radius: 8px;
			overflow: hidden;
		}
		.video-wrapper iframe {
			position: absolute;
			inset: 0;
			width: 100%;
			height: 100%;
			border: 0;
		}
		.video-fallback {
			font-size: 0.85rem;
			color: #666;
			margin-top: -1rem;
		}
		.meta {
			color: #666;
			font-size: 0.9rem;
		}
		.resumen {
			font-size: 1.1rem;
		}
		.atribucion {
			margin-top: 2.5rem;
			padding-top: 1.5rem;
			border-top: 1px solid #eee;
			font-size: 0.9rem;
			color: #444;
		}
	</style>
</Base>
