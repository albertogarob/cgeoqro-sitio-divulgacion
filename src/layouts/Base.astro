---
import { withBase } from '../lib/url';

interface Props {
  title: string;
}

const { title } = Astro.props;

const nav = [
  { href: '/', label: 'Inicio' },
  { href: '/capsulas/', label: 'Cápsulas' },
  { href: '/series/', label: 'Series' },
  { href: '/investigadores/', label: 'Investigadores' },
  { href: '/entrevistas/', label: '3 Preguntas a...' },
  { href: '/acerca-de/', label: 'Acerca de' },
];
---

<html lang="es">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href={withBase('/favicon.svg')} />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>{title} · CentroGeo QRO Divulgación</title>
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Archivo+Expanded:wght@500;600;700&family=Roboto+Flex:wght@300;400;500;600;700&display=swap"
			rel="stylesheet"
		/>
	</head>
	<body>
		<header>
			<a class="marca" href={withBase('/')}>
				<img src={withBase('/branding/logo-centrogeo.svg')} alt="CentroGeo" class="marca-logo" />
				<span class="marca-sitio">Divulgación QRO</span>
			</a>
			<nav>
				<ul>
					{nav.map((item) => (
						<li><a href={withBase(item.href)}>{item.label}</a></li>
					))}
				</ul>
			</nav>
		</header>
		<main class="cg-shell">
			<div class="cg-card">
				<slot />
			</div>
		</main>
		<footer>
			<p>
				Prototipo de divulgación científica de CentroGeo Querétaro. Los contenidos son
				elaboraciones propias inspiradas en publicaciones de investigadores del centro;
				no reproducen texto ni figuras de los papers originales, protegidos por derechos
				de autor de sus editoriales. Ver <a href={withBase('/acerca-de/')}>política de atribución</a>.
			</p>
		</footer>
		<style>
			/* Tokens de identidad visual real de CentroGeo (ver CLAUDE.md, sección
			   "Identidad visual institucional" y docs/referencia-visual/centrogeo-styles.css).
			   Tipografía: Roboto Flex (cuerpo) + Archivo Expanded (títulos, sustituto
			   gratuito de "ingra-wide" de Adobe Typekit, restringido al dominio de CentroGeo). */
			:global(:root) {
				--cg-color-blanco: #ffffff;
				--cg-color-naranja-100: #f4d2c1;
				--cg-color-naranja-300: #c45620;
				--cg-color-naranja-500: #9c4419;
				--cg-color-gris-100: #f3f3f3;
				--cg-color-gris-300: #d9d9d9;
				--cg-color-gris-500: #343434;
				--cg-color-gris-700: #232323;
				--cg-font-titulo: 'Archivo Expanded', sans-serif;
				--cg-font-cuerpo: 'Roboto Flex', system-ui, sans-serif;
				--cg-border-radius-s: 8px;
				--cg-border-radius-m: 16px;
				--cg-border-radius-b: 24px;
			}
			:global(body) {
				font-family: var(--cg-font-cuerpo);
				margin: 0;
				color: var(--cg-color-gris-500);
				background: var(--cg-color-gris-100);
			}
			:global(.cg-pill) {
				display: inline-flex;
				align-items: center;
				gap: 0.35rem;
				padding: 0.2rem 0.7rem;
				border-radius: 999px;
				background: var(--cg-color-naranja-100);
				color: var(--cg-color-naranja-500);
				font-size: 0.78rem;
				font-weight: 600;
				letter-spacing: 0.02em;
				text-decoration: none !important;
				white-space: nowrap;
			}
			:global(.cg-pill:hover) {
				background: var(--cg-color-naranja-300);
				color: var(--cg-color-blanco) !important;
			}
			:global(.cg-eyebrow) {
				display: block;
				font-family: var(--cg-font-cuerpo);
				font-size: 0.8rem;
				font-weight: 700;
				color: var(--cg-color-naranja-300);
				text-transform: uppercase;
				letter-spacing: 0.1em;
				margin-bottom: 0.5rem;
			}
			:global(.cg-btn) {
				display: inline-flex;
				align-items: center;
				gap: 0.4rem;
				padding: 0.7rem 1.4rem;
				border-radius: 999px;
				font-weight: 600;
				font-size: 0.95rem;
				text-decoration: none !important;
				transition: background-color 150ms ease, color 150ms ease, border-color 150ms ease;
			}
			:global(.cg-btn-primary) {
				background: var(--cg-color-naranja-300);
				color: var(--cg-color-blanco) !important;
				border: 1px solid var(--cg-color-naranja-300);
			}
			:global(.cg-btn-primary:hover) {
				background: var(--cg-color-naranja-500);
				border-color: var(--cg-color-naranja-500);
			}
			:global(.cg-btn-secondary) {
				background: transparent;
				color: var(--cg-color-gris-700) !important;
				border: 1px solid var(--cg-color-gris-300);
			}
			:global(.cg-btn-secondary:hover) {
				border-color: var(--cg-color-naranja-300);
				color: var(--cg-color-naranja-300) !important;
			}
			:global(.cg-list-card) {
				display: block;
				padding: 1.25rem 1.5rem;
				margin-bottom: 1rem;
				border-radius: var(--cg-border-radius-m);
				background: var(--cg-color-blanco);
				border: 1px solid var(--cg-color-gris-300);
				transition: border-color 150ms ease, transform 150ms ease;
				color: var(--cg-color-gris-500) !important;
				text-decoration: none !important;
			}
			:global(.cg-list-card h3) {
				color: var(--cg-color-gris-700) !important;
			}
			:global(.cg-list-card:hover) {
				border-color: var(--cg-color-naranja-300);
				transform: translateY(-2px);
			}
			:global(.cg-list-card h3),
			:global(.cg-list-card p:last-child) {
				margin: 0.4rem 0 0 0;
			}
			:global(h1),
			:global(h2),
			:global(h3),
			:global(h4) {
				font-family: var(--cg-font-titulo);
				font-weight: 600;
				color: var(--cg-color-gris-700);
				letter-spacing: -0.01em;
				line-height: 1.15;
			}
			:global(a) {
				color: var(--cg-color-naranja-300);
			}
			:global(a:hover) {
				color: var(--cg-color-naranja-500);
			}
			header {
				position: sticky;
				top: 0;
				z-index: 10;
				display: flex;
				flex-wrap: wrap;
				align-items: center;
				justify-content: space-between;
				gap: 1rem;
				padding: 1rem 1.5rem;
				background: var(--cg-color-blanco);
				box-shadow: 0 10px 22px -24px rgba(0, 0, 0, 0.4), 0 1px 0 var(--cg-color-gris-300);
			}
			.marca {
				display: inline-flex;
				align-items: center;
				gap: 0.75rem;
				text-decoration: none;
				color: var(--cg-color-gris-700) !important;
			}
			.marca-logo {
				height: 32px;
				width: auto;
				display: block;
			}
			.marca-sitio {
				font-family: var(--cg-font-titulo);
				font-weight: 600;
				font-size: 0.95rem;
				letter-spacing: 0.02em;
				padding-left: 0.75rem;
				border-left: 2px solid var(--cg-color-naranja-300);
			}
			nav ul {
				display: flex;
				flex-wrap: wrap;
				gap: 1.25rem;
				list-style: none;
				margin: 0;
				padding: 0;
			}
			nav a {
				text-decoration: none;
				color: var(--cg-color-gris-700);
				font-weight: 500;
				font-size: 0.95rem;
			}
			nav a:hover {
				color: var(--cg-color-naranja-300);
			}
			.cg-shell {
				max-width: 64rem;
				margin: 0 auto;
				padding: 2.5rem 1.5rem;
				min-height: 60vh;
			}
			.cg-card {
				background: var(--cg-color-blanco);
				border: 1px solid rgba(52, 52, 52, 0.08);
				border-radius: var(--cg-border-radius-b);
				box-shadow: 0 26px 60px -42px rgba(0, 0, 0, 0.28);
				padding: clamp(24px, 4vw, 56px);
			}
			@media (max-width: 640px) {
				.cg-shell {
					padding: 1.25rem 0.75rem;
				}
				.cg-card {
					border-radius: var(--cg-border-radius-m);
				}
			}
			footer {
				background: var(--cg-color-gris-700);
				color: var(--cg-color-gris-300);
				padding: 1.5rem;
				font-size: 0.85rem;
			}
			footer :global(a) {
				color: var(--cg-color-gris-300);
				text-decoration: underline;
			}
			footer :global(a:hover) {
				color: var(--cg-color-blanco);
			}
		</style>
	</body>
</html>
