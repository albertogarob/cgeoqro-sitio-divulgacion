---
import { withBase } from '../lib/url';

interface Props {
  title: string;
  bleed?: boolean;
}

const { title, bleed = false } = Astro.props;

const nav = [
  { href: '/', label: 'Inicio' },
  { href: '/capsulas/', label: 'Cápsulas' },
  { href: '/series/', label: 'Series' },
  { href: '/investigadores/', label: 'Investigadores' },
  { href: '/entrevistas/', label: '3 Preguntas a...' },
  { href: '/acerca-de/', label: 'Acerca de' },
];

// Nota: la franja gubernamental gob.mx/SECIHTI se retiró mientras el sitio sea un
// prototipo no autorizado por la institución. Al oficializarse, se puede reponer con
// los enlaces obligatorios del Gobierno de México.
const redes = [
  { href: 'https://www.facebook.com/CentroGeo/', label: 'Facebook' },
  { href: 'https://www.instagram.com/centrogeo_', label: 'Instagram' },
  { href: 'https://x.com/CentroGeo_', label: 'X' },
  { href: 'https://www.youtube.com/user/cigget', label: 'YouTube' },
];
---

<html lang="es">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href={withBase('/favicon.svg')} />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>{title} · Ciencia Geoespacial para Todos · CentroGeo Querétaro</title>
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Archivo+Expanded:wght@500;600;700&family=Roboto+Flex:wght@300;400;500;600;700&display=swap"
			rel="stylesheet"
		/>
	</head>
	<body>
		<div class="aviso-prototipo" role="note">
			<strong>Prototipo en construcción · sitio no oficial.</strong> Los logotipos e
			identidad institucional se muestran solo con fines de demostración; su uso aún no
			ha sido autorizado por CentroGeo.
		</div>
		<header>
			<a class="marca" href={withBase('/')}>
				<img src={withBase('/branding/logo-centrogeo.svg')} alt="CentroGeo" class="marca-logo" />
				<span class="marca-sitio">Ciencia Geoespacial<br />para Todos</span>
			</a>
			<nav>
				<ul>
					{nav.map((item) => (
						<li><a href={withBase(item.href)}>{item.label}</a></li>
					))}
				</ul>
			</nav>
		</header>
		<slot name="hero" />
		{bleed ? (
			<main class="cg-bleed">
				<slot />
			</main>
		) : (
			<main class="cg-shell">
				<div class="cg-card">
					<slot />
				</div>
			</main>
		)}

		<footer class="site-footer">
			<div class="site-footer-inner">
				<div class="footer-brand">
					<img src={withBase('/branding/logo-centrogeo-white.svg')} alt="CentroGeo" class="footer-logo" />
					<p>
						Divulgación científica de CentroGeo Querétaro. Traducimos la investigación de
						nuestros científicos a formatos accesibles para el público general.
					</p>
				</div>
				<div class="footer-col">
					<h2>Índice del sitio</h2>
					<ul>
						{nav.map((item) => (
							<li><a href={withBase(item.href)}>{item.label}</a></li>
						))}
						<li><a href={withBase('/quienes-somos/')}>¿Quiénes somos?</a></li>
						<li><a href={withBase('/centrogeo-queretaro/')}>¿Qué es el CentroGeo Querétaro?</a></li>
					</ul>
				</div>
				<div class="footer-col">
					<h2>CentroGeo</h2>
					<ul>
						<li><a href="https://www.centrogeo.org.mx/" target="_blank" rel="noopener">Sitio institucional</a></li>
						<li><a href="https://secihti.mx/" target="_blank" rel="noopener">SECIHTI</a></li>
						{redes.map((r) => (
							<li><a href={r.href} target="_blank" rel="noopener">{r.label}</a></li>
						))}
					</ul>
				</div>
			</div>
			<div class="footer-nota">
				<p>
					<strong>Prototipo no oficial, sin autorización institucional.</strong> Sitio de
					divulgación en construcción de CentroGeo Querétaro. Los logotipos e identidad
					institucional se muestran solo con fines de demostración. Los contenidos son
					elaboraciones propias inspiradas en publicaciones de investigadores del centro;
					no reproducen texto ni figuras de los papers originales, protegidos por derechos
					de autor de sus editoriales. Ver <a href={withBase('/acerca-de/')}>política de atribución</a>.
				</p>
			</div>
		</footer>

		<style>
			/* Tokens de identidad visual real de CentroGeo (ver CLAUDE.md, sección
			   "Identidad visual institucional" y docs/referencia-visual/centrogeo-styles.css).
			   Tipografía: Roboto Flex (cuerpo) + Archivo Expanded (títulos, sustituto
			   gratuito de "ingra-wide" de Adobe Typekit, restringido al dominio de CentroGeo). */
			:global(:root) {
				--cg-color-blanco: #ffffff;
				--cg-color-naranja-100: #f4d2c1;
				--cg-color-naranja-300: #c45620;
				--cg-color-naranja-500: #9c4419;
				--cg-color-gris-100: #f3f3f3;
				--cg-color-gris-300: #d9d9d9;
				--cg-color-gris-500: #343434;
				--cg-color-gris-700: #232323;
				--cg-color-vino: #611232;
				--cg-font-titulo: 'Archivo Expanded', sans-serif;
				--cg-font-cuerpo: 'Roboto Flex', system-ui, sans-serif;
				--cg-border-radius-s: 8px;
				--cg-border-radius-m: 16px;
				--cg-border-radius-b: 24px;
			}
			:global(body) {
				font-family: var(--cg-font-cuerpo);
				margin: 0;
				color: var(--cg-color-gris-500);
				background: var(--cg-color-gris-100);
			}
			/* Aviso de prototipo no oficial (barra superior). */
			.aviso-prototipo {
				background: #916802;
				color: #fff7e3;
				font-size: 0.82rem;
				line-height: 1.4;
				text-align: center;
				padding: 0.55rem 1rem;
			}
			.aviso-prototipo strong {
				color: #ffffff;
			}
			:global(h1),
			:global(h2),
			:global(h3),
			:global(h4) {
				font-family: var(--cg-font-titulo);
				font-weight: 600;
				color: var(--cg-color-gris-700);
				letter-spacing: -0.01em;
				line-height: 1.15;
			}
			:global(a) {
				color: var(--cg-color-naranja-300);
			}
			:global(a:hover) {
				color: var(--cg-color-naranja-500);
			}
			:global(.cg-pill) {
				display: inline-flex;
				align-items: center;
				gap: 0.35rem;
				padding: 0.2rem 0.7rem;
				border-radius: 999px;
				background: var(--cg-color-naranja-100);
				color: var(--cg-color-naranja-500);
				font-size: 0.78rem;
				font-weight: 600;
				letter-spacing: 0.02em;
				text-decoration: none !important;
				white-space: nowrap;
			}
			:global(.cg-pill:hover) {
				background: var(--cg-color-naranja-300);
				color: var(--cg-color-blanco) !important;
			}
			:global(.cg-eyebrow) {
				display: block;
				font-family: var(--cg-font-cuerpo);
				font-size: 0.8rem;
				font-weight: 700;
				color: var(--cg-color-naranja-300);
				text-transform: uppercase;
				letter-spacing: 0.1em;
				margin-bottom: 0.5rem;
			}
			:global(.cg-btn) {
				display: inline-flex;
				align-items: center;
				gap: 0.4rem;
				padding: 0.7rem 1.4rem;
				border-radius: 999px;
				font-weight: 600;
				font-size: 0.95rem;
				text-decoration: none !important;
				transition: background-color 150ms ease, color 150ms ease, border-color 150ms ease;
			}
			:global(.cg-btn-primary) {
				background: var(--cg-color-naranja-300);
				color: var(--cg-color-blanco) !important;
				border: 1px solid var(--cg-color-naranja-300);
			}
			:global(.cg-btn-primary:hover) {
				background: var(--cg-color-naranja-500);
				border-color: var(--cg-color-naranja-500);
			}
			:global(.cg-btn-secondary) {
				background: transparent;
				color: var(--cg-color-gris-700) !important;
				border: 1px solid var(--cg-color-gris-300);
			}
			:global(.cg-btn-secondary:hover) {
				border-color: var(--cg-color-naranja-300);
				color: var(--cg-color-naranja-300) !important;
			}
			:global(.cg-list-card) {
				display: block;
				padding: 1.25rem 1.5rem;
				margin-bottom: 1rem;
				border-radius: var(--cg-border-radius-m);
				background: var(--cg-color-blanco);
				border: 1px solid var(--cg-color-gris-300);
				transition: border-color 150ms ease, transform 150ms ease;
				color: var(--cg-color-gris-500) !important;
				text-decoration: none !important;
			}
			:global(.cg-list-card h3) {
				color: var(--cg-color-gris-700) !important;
			}
			:global(.cg-list-card:hover) {
				border-color: var(--cg-color-naranja-300);
				transform: translateY(-2px);
			}
			:global(.cg-list-card h3),
			:global(.cg-list-card p:last-child) {
				margin: 0.4rem 0 0 0;
			}

			/* ── HEADER ─────────────────────────────────────────── */
			header {
				position: sticky;
				top: 0;
				z-index: 10;
				display: flex;
				flex-wrap: wrap;
				align-items: center;
				justify-content: space-between;
				gap: 1rem;
				padding: 1rem 1.5rem;
				background: var(--cg-color-blanco);
				box-shadow: 0 10px 22px -24px rgba(0, 0, 0, 0.4), 0 1px 0 var(--cg-color-gris-300);
			}
			.marca {
				display: inline-flex;
				align-items: center;
				gap: 0.75rem;
				text-decoration: none;
				color: var(--cg-color-gris-700) !important;
			}
			.marca-logo {
				height: 34px;
				width: auto;
				display: block;
			}
			.marca-sitio {
				font-family: var(--cg-font-titulo);
				font-weight: 600;
				font-size: 0.82rem;
				line-height: 1.2;
				letter-spacing: 0.02em;
				padding-left: 0.75rem;
				border-left: 2px solid var(--cg-color-naranja-300);
			}
			nav ul {
				display: flex;
				flex-wrap: wrap;
				gap: 1.25rem;
				list-style: none;
				margin: 0;
				padding: 0;
			}
			nav a {
				text-decoration: none;
				color: var(--cg-color-gris-700);
				font-weight: 500;
				font-size: 0.95rem;
			}
			nav a:hover {
				color: var(--cg-color-naranja-300);
			}

			/* ── MAIN SHELL + CARD ──────────────────────────────── */
			.cg-shell {
				max-width: 64rem;
				margin: 0 auto;
				padding: 2.5rem 1.5rem;
				min-height: 60vh;
			}
			.cg-card {
				background: var(--cg-color-blanco);
				border: 1px solid rgba(52, 52, 52, 0.08);
				border-radius: var(--cg-border-radius-b);
				box-shadow: 0 26px 60px -42px rgba(0, 0, 0, 0.28);
				padding: clamp(24px, 4vw, 56px);
			}
			@media (max-width: 640px) {
				.cg-shell {
					padding: 1.25rem 0.75rem;
				}
				.cg-card {
					border-radius: var(--cg-border-radius-m);
				}
			}

			/* ── SITE FOOTER (banda oscura) ─────────────────────── */
			.site-footer {
				background: var(--cg-color-gris-700);
				color: var(--cg-color-gris-300);
			}
			.site-footer-inner {
				max-width: 68rem;
				margin: 0 auto;
				padding: 3rem 1.5rem 2rem;
				display: grid;
				grid-template-columns: 1.6fr 1fr 1fr;
				gap: 2.5rem;
			}
			.footer-logo {
				height: 40px;
				width: auto;
				margin-bottom: 1rem;
			}
			.footer-brand p {
				margin: 0;
				font-size: 0.9rem;
				max-width: 24rem;
				line-height: 1.5;
			}
			.footer-col h2 {
				font-size: 0.85rem;
				text-transform: uppercase;
				letter-spacing: 0.08em;
				color: var(--cg-color-blanco);
				margin: 0 0 1rem 0;
			}
			.footer-col ul {
				list-style: none;
				margin: 0;
				padding: 0;
			}
			.footer-col li {
				margin-bottom: 0.6rem;
			}
			.footer-col a {
				color: var(--cg-color-gris-300);
				text-decoration: none;
				font-size: 0.9rem;
			}
			.footer-col a:hover {
				color: var(--cg-color-blanco);
			}
			.footer-nota {
				border-top: 1px solid rgba(255, 255, 255, 0.12);
			}
			.footer-nota p {
				max-width: 68rem;
				margin: 0 auto;
				padding: 1.25rem 1.5rem;
				font-size: 0.8rem;
				color: rgba(255, 255, 255, 0.55);
				line-height: 1.5;
			}
			.footer-nota a {
				color: var(--cg-color-gris-300);
				text-decoration: underline;
			}
			.footer-nota a:hover {
				color: var(--cg-color-blanco);
			}

			@media (max-width: 760px) {
				.site-footer-inner {
					grid-template-columns: 1fr;
					gap: 2rem;
				}
			}
		</style>
	</body>
</html>
